.result-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  padding: 2rem 1.75rem;
  text-align: center;
  border-top: 5px solid;
}
.result-card--risk { border-top-color: var(--danger); }
.result-card--safe { border-top-color: var(--success); }

.result-icon { font-size: 2.8rem; margin-bottom: .6rem; line-height: 1; }

.result-label {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.4rem; font-weight: 700; margin-bottom: 1.25rem;
}
.result-card--risk .result-label { color: var(--danger); }
.result-card--safe .result-label { color: var(--teal); }

/* ─── Confidence ─────────────────────────────────────────────────────────── */
.confidence-wrap { margin-bottom: 1.25rem; }
.confidence-label {
  display: flex; justify-content: space-between;
  font-size: .8rem; font-weight: 600; color: var(--slate-600);
  margin-bottom: .4rem;
}
.confidence-pct { font-size: 1rem; font-weight: 700; color: var(--slate-800); }
.confidence-bar-bg {
  width: 100%; height: 10px; background: var(--slate-100);
  border-radius: 999px; overflow: hidden;
}
.confidence-bar-fill {
  height: 100%; border-radius: 999px;
  transition: width .8s cubic-bezier(.4,0,.2,1);
  background: linear-gradient(90deg, var(--sky) 0%, var(--teal) 100%);
}
.result-card--risk .confidence-bar-fill {
  background: linear-gradient(90deg, var(--warn) 0%, var(--danger) 100%);
}

/* ─── Text ───────────────────────────────────────────────────────────────── */
.result-advisory {
  font-size: .85rem; color: var(--slate-600);
  margin-bottom: .75rem; line-height: 1.6;
}
.result-time {
  font-size: .75rem; color: var(--slate-400); margin-bottom: .5rem;
}
.result-disclaimer {
  font-size: .72rem; color: var(--slate-400);
  background: var(--slate-50); border-radius: var(--radius-sm);
  padding: .4rem .75rem;
}
